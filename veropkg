# ---------------------------------------------------------------------------
# Exceptions
# ---------------------------------------------------------------------------

class VeroPkgError(Exception):       pass
class DependencyError(VeroPkgError): pass
class SecurityError(VeroPkgError):   pass
class ChecksumError(SecurityError):  pass
class FileConflictError(VeroPkgError): pass
class PackageNotFoundError(VeroPkgError): pass
class ValidationError(VeroPkgError): pass
class NetworkError(VeroPkgError):    pass
class LockError(VeroPkgError):       pass

# ---------------------------------------------------------------------------
# Input validation
# ---------------------------------------------------------------------------

def validate_package_name(name: str) -> str:
    """Return *name* unchanged if valid; raise ValidationError otherwise."""
    if not name:
        raise ValidationError("Package name cannot be empty.")
    if len(name) > 128:
        raise ValidationError(f"Package name too long ({len(name)} chars, max 128): {name!r}")
    if not _PKG_RE.match(name):
        raise ValidationError(
            f"Invalid package name: {name!r}. "
            "Must start with alphanumeric and contain only [a-zA-Z0-9._+-]."
        )
    return name

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def ensure_dirs() -> None:
    for d in (CACHE_DIR, DB_DIR, TRANSACTION_DIR, SYSTEM_ROOT):
        d.mkdir(parents=True, exist_ok=True)
    for path, default in ((INSTALLED_DB, {}), (FILES_DB, {}), (REPO_DB, DEFAULT_REPO)):
        if not path.exists():
            atomic_save_json(path, default)


def atomic_save_json(path: Path, data: dict) -> None:
    """Write *data* as JSON to *path* with an atomic rename."""
    path = Path(path)
    with tempfile.NamedTemporaryFile(
        "w", delete=False, dir=path.parent, suffix=".tmp"
    ) as tmp:
        json.dump(data, tmp, indent=4)
        tmp.flush()
        os.fsync(tmp.fileno())
        tmp_name = tmp.name
    os.replace(tmp_name, path)


def load_json(path: Path) -> dict:
    path = Path(path)
    if not path.exists():
        return {}
    with open(path) as f:
        return json.load(f)


def sha256sum(path: Path) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def require_root() -> None:
    """Raise VeroPkgError if not running as root (POSIX only)."""
    if os.name == "nt":
        return
    if hasattr(os, "geteuid") and os.geteuid() != 0:
        raise VeroPkgError("Root privileges required. Re-run with sudo.")


def make_ssl_context() -> ssl.SSLContext:
    ctx = ssl.create_default_context()
    ctx.minimum_version = ssl.TLSVersion.TLSv1_2
    return ctx


def is_safe_path(base: str, target: str) -> bool:
    """Return True iff *target* is inside *base* (no traversal)."""
    base_real   = os.path.realpath(os.path.abspath(base))
    target_real = os.path.realpath(os.path.abspath(target))
    return target_real == base_real or target_real.startswith(base_real + os.sep)


def safe_extract(tar: tarfile.TarFile, dest: str) -> list[str]:
    """Extract *tar* into *dest* with full security checks."""
    extracted: list[str] = []
    for member in tar.getmembers():
        target = os.path.join(dest, member.name)

        if not is_safe_path(dest, target):
            raise SecurityError(f"Path traversal in archive: {member.name!r}")
        if member.issym() or member.islnk():
            raise SecurityError(f"Symlinks/hardlinks forbidden: {member.name!r}")
        if member.isdev():
            raise SecurityError(f"Device nodes forbidden: {member.name!r}")
        if member.size > MAX_DOWNLOAD_BYTES:
            raise SecurityError(
                f"File too large ({member.size:,} bytes): {member.name!r}"
            )

        extracted.append(member.name)

        if member.isdir():
            Path(target).mkdir(parents=True, exist_ok=True)
            continue

        src = tar.extractfile(member)
        if src is None:
            continue

        Path(target).parent.mkdir(parents=True, exist_ok=True)
        with open(target, "wb") as dst:
            shutil.copyfileobj(src, dst, length=65536)

    return extracted

# ---------------------------------------------------------------------------
# Locking
# ---------------------------------------------------------------------------

class PackageLock:
    """Process-level exclusive lock around all mutating operations."""

    def __enter__(self):
        LOCKFILE.parent.mkdir(parents=True, exist_ok=True)
        self._fd = open(LOCKFILE, "w")
        if HAS_FCNTL:
            try:
                fcntl.flock(self._fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
            except OSError:
                self._fd.close()
                raise LockError(
                    f"Another veropkg process is running (lock: {LOCKFILE}). "
                    "Wait for it to finish or remove the lock file if stale."
                )
        return self

    def __exit__(self, *_):
        if HAS_FCNTL:
            fcntl.flock(self._fd, fcntl.LOCK_UN)
        self._fd.close()

# ---------------------------------------------------------------------------
# Repository
# ---------------------------------------------------------------------------

class Repository:
    def __init__(self):
        self.repo: dict = load_json(REPO_DB)

    def sync(self) -> None:
        print(f"Syncing repository from {REPO_URL} ...")
        try:
            ctx = make_ssl_context()
            req = urllib.request.Request(
                REPO_URL,
                headers={"User-Agent": f"veropkg/{__version__}"},
            )
            with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:
                if resp.status != 200:
                    raise VeroPkgError(f"HTTP {resp.status} from repository server")
                raw = resp.read(MAX_REPO_BYTES)

            data = json.loads(raw.decode())
            atomic_save_json(REPO_DB, data)
            self.repo = data
            print(f"✓ Repository updated  ({len(data)} packages)")
            log.debug("Repo synced: %d packages", len(data))

        except urllib.error.URLError as e:
            raise NetworkError(f"Failed to connect to repository: {e.reason}")
        except VeroPkgError:
            raise
        except Exception as exc:
            log.warning("Sync failed: %s", exc)
            print(f"  Sync failed: {exc}")
            print("  Using cached repository.")

# ---------------------------------------------------------------------------
# Dependency resolution
# ---------------------------------------------------------------------------

class DependencyResolver:
    def __init__(self, repo: dict):
        self.repo = repo

    def resolve(self, target: str) -> list[str]:
        """Return a topologically-sorted install list (deps before target)."""
        if target not in self.repo:
            raise PackageNotFoundError(f"Package not found: {target!r}")

        result:  list[str] = []
        visited: set[str]  = set()
        stack:   list[str] = []   # used for cycle detection

        def dfs(pkg: str) -> None:
            if pkg in stack:
                cycle = " → ".join(stack) + f" → {pkg}"
                raise DependencyError(f"Circular dependency detected: {cycle}")
            if pkg in visited:
                return

            stack.append(pkg)
            for dep in self.repo[pkg].get("deps", []):
                if dep not in self.repo:
                    raise DependencyError(
                        f"Missing dependency {dep!r} required by {pkg!r}"
                    )
                dfs(dep)
            stack.pop()
            visited.add(pkg)
            result.append(pkg)

        dfs(target)
        return result

    def reverse_deps(self, target: str, installed: dict) -> list[str]:
        """Return all *installed* packages that declare *target* as a dep."""
        return [
            pkg for pkg, meta in self.repo.items()
            if target in meta.get("deps", []) and pkg in installed
        ]

# ---------------------------------------------------------------------------
# Transaction (rollback support)
# ---------------------------------------------------------------------------

class Transaction:
    def __init__(self):
        self.id   = datetime.utcnow().strftime("%Y%m%d%H%M%S%f")
        self.path = TRANSACTION_DIR / self.id
        self.path.mkdir(parents=True, exist_ok=True)
        self._rollback_log:  list[dict] = []
        self._created_files: list[str]  = []
        self._committed = False

    def __enter__(self):
        return self

    def __exit__(self, exc_type, *_):
        if exc_type is not None or not self._committed:
            self._rollback()

    def backup(self, target: Path) -> None:
        target = Path(target)
        if not target.exists():
            return
        bak = self.path / target.relative_to(target.anchor)
        bak.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(target, bak)
        self._rollback_log.append({"original": str(target), "backup": str(bak)})

    def register_created(self, path: Path) -> None:
        self._created_files.append(str(path))

    def commit(self) -> None:
        self._committed = True

    def _rollback(self) -> None:
        log.warning("Rolling back transaction %s", self.id)
        print("  Rolling back changes ...")

        for path_str in reversed(self._created_files):
            p = Path(path_str)
            if p.exists():
                try:
                    p.unlink()
                except Exception as e:
                    log.error("Rollback: could not remove %s: %s", p, e)

        for item in reversed(self._rollback_log):
            orig, bak = Path(item["original"]), Path(item["backup"])
            if bak.exists():
                try:
                    shutil.copy2(bak, orig)
                except Exception as e:
                    log.error("Rollback: could not restore %s: %s", orig, e)

        print("  Rollback complete.")

# ---------------------------------------------------------------------------
# Installer
# ---------------------------------------------------------------------------

class Installer:
    def __init__(self, repo: dict):
        self.repo       = repo
        self.installed  = load_json(INSTALLED_DB)
        self.files_db   = load_json(FILES_DB)

    def install(self, pkg: str) -> None:
        pkg = validate_package_name(pkg)
        plan = DependencyResolver(self.repo).resolve(pkg)

        to_install = [p for p in plan if p not in self.installed]
        if not to_install:
            print(f"{pkg} is already installed.")
            return

        print(f"\nInstallation plan ({len(to_install)} package(s)):")
        for i, p in enumerate(to_install, 1):
            label = "" if p == pkg else "  [dependency]"
            print(f"  [{i}/{len(to_install)}] {p} ({self.repo[p]['version']}){label}")
        print()

        with Transaction() as tx:
            for p in to_install:
                self._install_one(p, tx, auto=(p != pkg))
            atomic_save_json(INSTALLED_DB, self.installed)
            atomic_save_json(FILES_DB, self.files_db)
            tx.commit()

        print(f"\n✓ {pkg} installed successfully.")

    def _install_one(self, pkg: str, tx: Transaction, auto: bool = False) -> None:
        meta         = self.repo[pkg]
        package_path = CACHE_DIR / f"{pkg}.vpkg"
        staging: str | None = None

        print(f"  Downloading {pkg} {meta['version']} ...")
        log.debug("  url = %s", meta["url"])

        try:
            if meta["url"] != "demo":
                ctx = make_ssl_context()
                req = urllib.request.Request(
                    meta["url"],
                    headers={"User-Agent": f"veropkg/{__version__}"},
                )
                try:
                    with urllib.request.urlopen(req, context=ctx, timeout=60) as resp:
                        with open(package_path, "wb") as fout:
                            shutil.copyfileobj(resp, fout, length=65536)
                except urllib.error.URLError as e:
                    raise NetworkError(f"Download failed for {pkg}: {e.reason}")
            else:
                # Demo stub: create a minimal tar.gz
                with tarfile.open(package_path, "w:gz") as tar:
                    import io
                    content = f"#!/bin/sh\necho '{pkg} running'\n".encode()
                    info        = tarfile.TarInfo(name=f"usr/bin/{pkg}")
                    info.size   = len(content)
                    info.mode   = 0o755
                    tar.addfile(info, io.BytesIO(content))

            # Verify checksum
            expected = meta.get("sha256")
            if expected and expected != "demo":
                print(f"  Verifying {pkg} ...")
                actual = sha256sum(package_path)
                if actual != expected:
                    raise ChecksumError(
                        f"SHA256 mismatch for {pkg}:\n"
                        f"  expected {expected}\n"
                        f"  got      {actual}"
                    )
                log.debug("  SHA256 OK")

            print(f"  Extracting {pkg} ...")
            staging = tempfile.mkdtemp(prefix="veropkg-")

            with tarfile.open(package_path) as tar:
                extracted = safe_extract(tar, staging)

            manifest: list[str] = []
            for relpath in extracted:
                src = Path(staging) / relpath
                if src.is_dir():
                    continue

                dest = SYSTEM_ROOT / relpath
                owner = self.files_db.get(str(dest))
                if owner and owner != pkg:
                    raise FileConflictError(
                        f"File conflict: {dest} is owned by {owner!r}"
                    )

                dest.parent.mkdir(parents=True, exist_ok=True)
                if dest.exists():
                    tx.backup(dest)

                shutil.copy2(src, dest)
                tx.register_created(dest)
                os.chmod(dest, 0o755)
                manifest.append(str(dest))
                self.files_db[str(dest)] = pkg

            self.installed[pkg] = {
                "version":        meta["version"],
                "installed_at":   datetime.utcnow().isoformat() + "Z",
                "auto_installed": auto,
                "files":          manifest,
            }
            print(f"  ✓ {pkg}")

        finally:
            if staging and Path(staging).exists():
                shutil.rmtree(staging, ignore_errors=True)

# ---------------------------------------------------------------------------
# Remover
# ---------------------------------------------------------------------------

class Remover:
    def __init__(self, repo: dict):
        self.repo      = repo
        self.installed = load_json(INSTALLED_DB)
        self.files_db  = load_json(FILES_DB)

    def remove(self, pkg: str, force: bool = False) -> None:
        pkg = validate_package_name(pkg)
        if pkg not in self.installed:
            print(f"{pkg} is not installed.")
            return

        dependents = DependencyResolver(self.repo).reverse_deps(pkg, self.installed)
        if dependents and not force:
            print(f"Cannot remove {pkg!r} — required by:")
            for d in dependents:
                print(f"  {d}")
            print("\nPass --force to override (may break other packages).")
            return

        print(f"Removing {pkg} ...")
        for f in self.installed[pkg].get("files", []):
            p = Path(f)
            if p.exists():
                try:
                    p.unlink()
                except Exception as exc:
                    log.warning("Could not remove %s: %s", p, exc)
            self.files_db.pop(f, None)

        del self.installed[pkg]
        atomic_save_json(INSTALLED_DB, self.installed)
        atomic_save_json(FILES_DB, self.files_db)
        print(f"✓ Removed {pkg}.")

    def autoremove(self) -> None:
        """Iteratively remove auto-installed packages no longer required."""
        removed: list[str] = []
        changed = True

        while changed:
            changed = False
            for pkg, meta in list(self.installed.items()):
                if not meta.get("auto_installed"):
                    continue
                if not DependencyResolver(self.repo).reverse_deps(pkg, self.installed):
                    print(f"  Removing unused dependency: {pkg}")
                    self.remove(pkg)
                    removed.append(pkg)
                    changed = True
                    break   # restart after mutation

        if removed:
            print(f"\n✓ Removed {len(removed)} unused package(s): {', '.join(removed)}")
        else:
            print("No unused packages to remove.")

# ---------------------------------------------------------------------------
# Upgrader
# ---------------------------------------------------------------------------

class Upgrader:
    def __init__(self, repo: dict):
        self.repo = repo
        self.installed = load_json(INSTALLED_DB)
        self.files_db = load_json(FILES_DB)

    def upgrade_all(self) -> None:
        """Finds and upgrades all installed packages with a newer version in the repo."""
        upgradable = []
        for pkg, meta in self.installed.items():
            if pkg in self.repo:
                installed_ver = version.parse(meta["version"])
                repo_ver = version.parse(self.repo[pkg]["version"])
                if repo_ver > installed_ver:
                    upgradable.append(pkg)

        if not upgradable:
            print("All packages are up-to-date.")
            return

        print(f"Found {len(upgradable)} package(s) to upgrade: {', '.join(upgradable)}")
        for pkg in upgradable:
            self.upgrade_package(pkg)

    def upgrade_package(self, pkg: str) -> None:
        """Upgrades a single package and its dependencies safely."""
        pkg = validate_package_name(pkg)
        if pkg not in self.installed:
            print(f"{pkg} is not installed. Use 'install' to install it first.")
            return
        if pkg not in self.repo:
            print(f"Warning: {pkg} is not in the current repository.")
            return

        installed_ver = version.parse(self.installed[pkg]["version"])
        repo_ver = version.parse(self.repo[pkg]["version"])

        if repo_ver <= installed_ver:
            print(f"{pkg} is already at the latest version ({installed_ver}).")
            return

        print(f"\nUpgrading {pkg} ({installed_ver} -> {repo_ver}) ...")

        installer = Installer(self.repo)
        plan = DependencyResolver(self.repo).resolve(pkg)

        # Filter the plan for packages that are missing OR have an available upgrade
        to_install = []
        for p in plan:
            if p not in self.installed:
                to_install.append(p)
            elif version.parse(self.repo[p]["version"]) > version.parse(self.installed[p]["version"]):
                to_install.append(p)

        # Snapshot the old files to detect orphaned files after the upgrade
        old_files_map = {p: set(self.installed.get(p, {}).get("files", [])) for p in to_install}

        with Transaction() as tx:
            for p in to_install:
                # Maintain the "auto_installed" flag for dependencies during upgrade
                is_auto = self.installed.get(p, {}).get("auto_installed", p != pkg)
                installer._install_one(p, tx, auto=is_auto)

            # Cleanup orphaned files (files present in the old version but absent in the new)
            for p in to_install:
                if p in old_files_map:
                    new_files = set(installer.installed[p].get("files", []))
                    orphans = old_files_map[p] - new_files
                    for f in orphans:
                        p_path = Path(f)
                        if p_path.exists():
                            tx.backup(p_path)
                            try:
                                p_path.unlink()
                            except Exception as exc:
                                log.warning("Could not remove orphaned file %s: %s", p_path, exc)
                        installer.files_db.pop(f, None)

            # Commit the shared installer state
            atomic_save_json(INSTALLED_DB, installer.installed)
            atomic_save_json(FILES_DB, installer.files_db)
            tx.commit()

        print(f"✓ Upgrade of {pkg} complete.")
        
        # Sync back the local state
        self.installed = installer.installed
        self.files_db = installer.files_db

# ---------------------------------------------------------------------------
# Sandbox
# ---------------------------------------------------------------------------

class SandboxEngine:
    def __init__(self, pkg: str):
        self.pkg      = validate_package_name(pkg)
        self.app_home = SANDBOX_HOME / pkg

    def build_cmd(self) -> list[str]:
        self.app_home.mkdir(parents=True, exist_ok=True)
        bin_path = str(SYSTEM_ROOT / "usr" / "bin" / self.pkg)
        return [
            "bwrap",
            "--ro-bind", str(SYSTEM_ROOT / "usr"), "/usr",
            "--proc",  "/proc",
            "--dev",   "/dev",
            "--tmpfs", "/tmp",
            "--bind",  str(self.app_home), str(Path.home()),
            "--unshare-net",       # no network access by default
            "--die-with-parent",   # clean up if launcher dies
            bin_path,
        ]

    def launch(self) -> None:
        cmd = self.build_cmd()
        log.debug("Sandbox cmd: %s", " ".join(cmd))
        print(f"Launching {self.pkg} in sandbox ...")
        try:
            os.execvp("bwrap", cmd)
        except FileNotFoundError:
            raise VeroPkgError(
                "bubblewrap (bwrap) is not installed. "
                "Install it with your host package manager first."
            )

# ---------------------------------------------------------------------------
# Display helpers
# ---------------------------------------------------------------------------

def list_installed(verbose: bool = False) -> None:
    db = load_json(INSTALLED_DB)
    if not db:
        print("No packages installed.")
        return

    manual = {k: v for k, v in db.items() if not v.get("auto_installed")}
    auto   = {k: v for k, v in db.items() if     v.get("auto_installed")}

    print(f"Installed packages  ({len(db)} total, {len(auto)} auto-installed)\n")
    for pkg, meta in sorted(manual.items()):
        line = f"  {pkg:<30} {meta['version']}"
        if verbose:
            line += f"  installed {meta.get('installed_at', '?')}"
        print(line)

    if auto:
        print("\nAuto-installed dependencies:\n")
        for pkg, meta in sorted(auto.items()):
            line = f"  {pkg:<30} {meta['version']}  [auto]"
            if verbose:
                line += f"  installed {meta.get('installed_at', '?')}"
            print(line)


def cmd_search(repo: dict, term: str) -> None:
    term_l = term.lower()
    installed = load_json(INSTALLED_DB)
    hits = [(p, m["version"]) for p, m in repo.items() if term_l in p.lower()]
    if not hits:
        print(f"No packages found matching {term!r}.")
        return
    print(f"Results for {term!r}:\n")
    for pkg, ver in sorted(hits):
        marker = "  [installed]" if pkg in installed else ""
        print(f"  {pkg:<30} {ver}{marker}")


def cmd_info(repo: dict, pkg: str) -> None:
    pkg = validate_package_name(pkg)
    if pkg not in repo:
        print(f"Package not found: {pkg!r}")
        return
    meta      = repo[pkg]
    installed = load_json(INSTALLED_DB)
    status    = "installed" if pkg in installed else "not installed"
    deps      = ", ".join(meta.get("deps", [])) or "(none)"
    print(f"\n  Package : {pkg}")
    print(f"  Version : {meta['version']}")
    print(f"  Status  : {status}")
    print(f"  Deps    : {deps}")
    print(f"  URL     : {meta.get('url', 'N/A')}")
    if pkg in installed:
        n_files = len(installed[pkg].get("files", []))
        print(f"  Files   : {n_files}")

