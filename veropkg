# ==========================================================
# PACKAGE REMOVAL
# ==========================================================

class Remover:
    def __init__(self, repo):
        self.repo = repo
        self.installed = load_json(INSTALLED_DB)

    def remove(self, pkg):
        if pkg not in self.installed:
            print(f"❌ {pkg} is not installed.")
            return

        dependents = self.find_dependents(pkg)

        if dependents:
            print(f"❌ Cannot remove {pkg}.")
            print("Required by:")
            for d in dependents:
                print(f"  - {d}")
            return

        print(f"🗑 Removing {pkg}...")

        del self.installed[pkg]

        save_json(INSTALLED_DB, self.installed)

        print(f"✅ Removed {pkg}")

    def find_dependents(self, target):
        dependents = []

        for pkg, meta in self.repo.items():
            deps = meta.get("deps", [])

            if target in deps and pkg in self.installed:
                dependents.append(pkg)

        return dependents

# ==========================================================
# SANDBOX ENGINE
# ==========================================================

class SandboxEngine:
    def __init__(self, pkg):
        self.pkg = pkg

        self.app_home = SANDBOX_HOME / pkg

        self.wayland_display = os.environ.get(
            "WAYLAND_DISPLAY",
            "wayland-0"
        )

        self.runtime_dir = os.environ.get(
            "XDG_RUNTIME_DIR",
            "/run/user/1000"
        )

    def create(self):
        self.app_home.mkdir(parents=True, exist_ok=True)

        socket_path = (
            f"{self.runtime_dir}/{self.wayland_display}"
        )

        cmd = [
            "bwrap",

            # Filesystem isolation
            "--ro-bind", "/usr", "/usr",
            "--ro-bind", "/lib", "/lib",
            "--ro-bind", "/lib64", "/lib64",
            "--ro-bind", "/bin", "/bin",
            "--ro-bind", "/etc/fonts", "/etc/fonts",

            # Device access
            "--dev", "/dev",

            # Proc
            "--proc", "/proc",

            # Temp dirs
            "--tmpfs", "/tmp",
            "--tmpfs", "/run",

            # Wayland
            "--ro-bind", socket_path, socket_path,

            # Isolated HOME
            "--bind", str(self.app_home), str(Path.home()),

            # Namespaces
            "--unshare-pid",
            "--unshare-ipc",
            "--unshare-uts",
            "--unshare-cgroup",
            "--unshare-user",

            # Network
            "--share-net",

            # App
            f"/usr/bin/{self.pkg}"
        ]

        return cmd

    def launch(self):
        cmd = self.create()

        print(f"🛡 Launching {self.pkg} in sandbox...\n")

        try:
            os.execvp("bwrap", cmd)

        except FileNotFoundError:
            print("❌ bubblewrap (bwrap) is not installed.")
            sys.exit(1)

# ==========================================================
# PACKAGE LISTING
# ==========================================================

def list_installed():
    db = load_json(INSTALLED_DB)

    if not db:
        print("No packages installed.")
        return

    print("\n📦 Installed Packages:\n")

    for pkg, meta in db.items():
        print(f"{pkg} ({meta['version']})")

# ==========================================================
# SEARCH
# ==========================================================

def search_packages(repo, term):
    print(f"\n🔍 Searching for '{term}'...\n")

    found = False

    for pkg, meta in repo.items():
        if term.lower() in pkg.lower():
            print(f"{pkg} ({meta['version']})")
            found = True

    if not found:
        print("No matching packages found.")

# ==========================================================
# MAIN CLI
# ==========================================================

def main():
    ensure_dirs()

    parser = argparse.ArgumentParser(
        description="veropkg - Simple. Secure. Yours."
    )

    sub = parser.add_subparsers(
        dest="command",
        required=True
    )

    # install
    p_install = sub.add_parser(
        "install",
        help="Install package"
    )
    p_install.add_argument("package")

    # remove
    p_remove = sub.add_parser(
        "remove",
        help="Remove package"
    )
    p_remove.add_argument("package")

    # run
    p_run = sub.add_parser(
        "run",
        help="Run app in sandbox"
    )
    p_run.add_argument("package")

    # sync
    sub.add_parser(
        "sync",
        help="Sync repositories"
    )

    # list
    sub.add_parser(
        "list",
        help="List installed packages"
    )

    # search
    p_search = sub.add_parser(
        "search",
        help="Search repository"
    )
    p_search.add_argument("term")

    args = parser.parse_args()

    repo = Repository()

    if args.command == "sync":
        repo.sync()

    elif args.command == "install":
        installer = Installer(repo.repo)
        installer.install(args.package)

    elif args.command == "remove":
        remover = Remover(repo.repo)
        remover.remove(args.package)

    elif args.command == "run":
        sandbox = SandboxEngine(args.package)
        sandbox.launch()

    elif args.command == "list":
        list_installed()

    elif args.command == "search":
        search_packages(repo.repo, args.term)

# ==========================================================
# ENTRYPOINT
# ==========================================================

if __name__ == "__main__":
    main()
