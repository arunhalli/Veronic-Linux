# ==========================================================
# FILESYSTEM INIT
# ==========================================================

def ensure_dirs():
    VEROPKG_ROOT.mkdir(parents=True, exist_ok=True)
    CACHE_DIR.mkdir(parents=True, exist_ok=True)

    if not INSTALLED_DB.exists():
        save_json(INSTALLED_DB, {})

    if not REPO_DB.exists():
        save_json(REPO_DB, DEFAULT_REPO)

# ==========================================================
# JSON HELPERS
# ==========================================================

def load_json(path):
    with open(path, "r") as f:
        return json.load(f)

def save_json(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=4)

# ==========================================================
# REPOSITORY MANAGEMENT
# ==========================================================

class Repository:
    def __init__(self):
        self.repo = load_json(REPO_DB)

    def sync(self):
        print("🔄 Syncing repository metadata...")

        try:
            with urllib.request.urlopen(REPO_URL) as response:
                data = json.loads(response.read().decode())

            save_json(REPO_DB, data)

            self.repo = data

            print("✅ Repository updated successfully.")

        except Exception as e:
            print(f"⚠️  Failed to sync repository:")
            print(e)
            print("Using local repository cache.")

# ==========================================================
# DEPENDENCY RESOLUTION
# ==========================================================

class DependencyResolver:
    def __init__(self, repo):
        self.repo = repo

    def resolve(self, target):
        if target not in self.repo:
            raise Exception(f"Package '{target}' not found.")

        visited = set()
        stack = set()
        result = []

        def dfs(pkg):
            if pkg in stack:
                raise Exception(f"Circular dependency detected: {pkg}")

            if pkg in visited:
                return

            stack.add(pkg)

            deps = self.repo[pkg].get("deps", [])

            for dep in deps:
                if dep not in self.repo:
                    raise Exception(f"Missing dependency: {dep}")

                dfs(dep)

            stack.remove(pkg)
            visited.add(pkg)

            result.append(pkg)

        dfs(target)

        return result

# ==========================================================
# PACKAGE INSTALLER
# ==========================================================

class Installer:
    def __init__(self, repo):
        self.repo = repo
        self.installed = load_json(INSTALLED_DB)

    def is_installed(self, pkg):
        return pkg in self.installed

    def install(self, pkg):
        resolver = DependencyResolver(self.repo)

        plan = resolver.resolve(pkg)

        print("\n📦 Installation Plan:")
        for i, p in enumerate(plan, 1):
            print(f"  [{i}/{len(plan)}] {p}")

        for p in plan:
            if self.is_installed(p):
                print(f"✔ {p} already installed.")
                continue

            self.install_package(p)

        save_json(INSTALLED_DB, self.installed)

        print("\n✅ Installation complete.")

    def install_package(self, pkg):
        metadata = self.repo[pkg]

        print(f"\n⬇ Downloading {pkg}...")

        package_path = CACHE_DIR / f"{pkg}.vpkg"

        # MOCK DOWNLOAD
        with open(package_path, "w") as f:
            f.write("MOCK PACKAGE DATA")

        print(f"🔐 Verifying signature for {pkg}...")

        self.verify_signature(package_path)

        print(f"📂 Extracting {pkg}...")

        # MOCK EXTRACTION
        os.makedirs(f"/tmp/veropkg/{pkg}", exist_ok=True)

        self.installed[pkg] = {
            "version": metadata["version"],
            "installed_at": datetime.utcnow().isoformat()
        }

        print(f"✅ Installed {pkg}")

    def verify_signature(self, package_path):
