# Self-tests
# ---------------------------------------------------------------------------

def run_self_tests() -> None:
    import io
    failures = 0

    def ok(name: str) -> None:
        print(f"  ✓  {name}")

    def fail(name: str, reason: str = "") -> None:
        nonlocal failures
        msg = f"  ✗  {name}"
        if reason:
            msg += f": {reason}"
        print(msg)
        failures += 1

    def check(name: str, condition: bool, reason: str = "") -> None:
        ok(name) if condition else fail(name, reason)

    print("Running veropkg self-tests …\n")

    # -- is_safe_path --
    check("is_safe_path: child",         is_safe_path("/tmp", "/tmp/a"))
    check("is_safe_path: same",          is_safe_path("/tmp", "/tmp"))
    if os.name != "nt":
        check("is_safe_path: traversal blocked",  not is_safe_path("/tmp", "/etc/passwd"))
        check("is_safe_path: normalised traversal blocked",
              not is_safe_path("/tmp", "/tmp/../etc/passwd"))
    check("is_safe_path: prefix collision blocked",
          not is_safe_path("/tmp", "/tmp2/file"))

    # -- validate_package_name --
    for good in ["firefox", "lib32-glibc", "python3.11", "pkg+ext"]:
        try:
            validate_package_name(good)
            ok(f"validate_package_name: accept {good!r}")
        except ValidationError as e:
            fail(f"validate_package_name: accept {good!r}", str(e))

    for bad in ["", "../../etc/passwd", "-badpkg", "pkg;rm", "a" * 129]:
        try:
            validate_package_name(bad)
            fail(f"validate_package_name: reject {bad[:20]!r}", "should have raised")
        except ValidationError:
            ok(f"validate_package_name: reject {bad[:20]!r}")

    # -- DependencyResolver --
    resolver = DependencyResolver(DEFAULT_REPO)
    plan = resolver.resolve("firefox")
    check("resolve: glibc in plan",   "glibc"   in plan)
    check("resolve: mesa in plan",    "mesa"     in plan)
    check("resolve: firefox in plan", "firefox"  in plan)
    check("resolve: order glibc<mesa",    plan.index("glibc") < plan.index("mesa"))
    check("resolve: order mesa<firefox",  plan.index("mesa")  < plan.index("firefox"))

    try:
        DependencyResolver(DEFAULT_REPO).resolve("__nonexistent__")
        fail("resolve: unknown package raises")
    except PackageNotFoundError:
        ok("resolve: unknown package raises PackageNotFoundError")

    circular = {
        "a": {"version": "1", "deps": ["b"], "url": "demo", "sha256": "demo"},
        "b": {"version": "1", "deps": ["a"], "url": "demo", "sha256": "demo"},
    }
    try:
        DependencyResolver(circular).resolve("a")
        fail("resolve: circular dep raises")
    except DependencyError:
        ok("resolve: circular dep raises DependencyError")

    three_way = {
        "a": {"version": "1", "deps": ["b"], "url": "demo", "sha256": "demo"},
        "b": {"version": "1", "deps": ["c"], "url": "demo", "sha256": "demo"},
        "c": {"version": "1", "deps": ["a"], "url": "demo", "sha256": "demo"},
    }
    try:
        DependencyResolver(three_way).resolve("a")
        fail("resolve: 3-way cycle raises")
    except DependencyError:
        ok("resolve: 3-way cycle raises DependencyError")

    missing_dep = {
        "pkg": {"version": "1", "deps": ["ghost"], "url": "demo", "sha256": "demo"},
    }
    try:
        DependencyResolver(missing_dep).resolve("pkg")
        fail("resolve: missing dep raises")
    except DependencyError:
        ok("resolve: missing dep raises DependencyError")

    # -- atomic_save_json / load_json --
    with tempfile.TemporaryDirectory() as td:
        p = Path(td) / "test.json"
        atomic_save_json(p, {"hello": "world", "n": 42})
        loaded = load_json(p)
        check("atomic_save_json roundtrip", loaded == {"hello": "world", "n": 42})

    check("load_json missing file → {}", load_json("/nonexistent/__missing__.json") == {})

    # -- sha256sum --
    with tempfile.NamedTemporaryFile(delete=False) as f:
        f.write(b"hello world")
        tmp_path = f.name
    try:
        import hashlib
        expected = hashlib.sha256(b"hello world").hexdigest()
        check("sha256sum known value", sha256sum(tmp_path) == expected)
    finally:
        os.unlink(tmp_path)

    # -- safe_extract: path traversal blocked --
    fd, tpath = tempfile.mkstemp(suffix=".tar.gz")
    os.close(fd)
    with tarfile.open(tpath, "w:gz") as tar:
        info      = tarfile.TarInfo(name="../../../etc/evil")
        info.size = 4
        tar.addfile(info, io.BytesIO(b"evil"))
    with tempfile.TemporaryDirectory() as staging:
        try:
            with tarfile.open(tpath) as tar:
                safe_extract(tar, staging)
            fail("safe_extract: traversal blocked")
        except SecurityError:
            ok("safe_extract: traversal blocked")
    os.unlink(tpath)

    # -- safe_extract: symlink blocked --
    fd, tpath = tempfile.mkstemp(suffix=".tar.gz")
    os.close(fd)
    with tarfile.open(tpath, "w:gz") as tar:
        info          = tarfile.TarInfo(name="usr/bin/evil")
        info.type     = tarfile.SYMTYPE
        info.linkname = "/etc/passwd"
        tar.addfile(info)
    with tempfile.TemporaryDirectory() as staging:
        try:
            with tarfile.open(tpath) as tar:
                safe_extract(tar, staging)
            fail("safe_extract: symlink blocked")
        except SecurityError:
            ok("safe_extract: symlink blocked")
    os.unlink(tpath)

    # Summary
    print()
    if failures:
        print(f"FAILED — {failures} test(s) did not pass.")
        sys.exit(1)
    else:
        print("All tests passed ✓")

# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def setup_logging(verbose: bool) -> None:
    logging.basicConfig(
        level=logging.DEBUG if verbose else logging.WARNING,
        format="[%(levelname)s] %(name)s: %(message)s",
    )


def main() -> None:
    ensure_dirs()

    parser = argparse.ArgumentParser(
        prog="veropkg",
        description="veropkg — Veronic Linux Package Manager",
    )
    parser.add_argument("--version", action="version", version=f"veropkg {__version__}")
    parser.add_argument("-v", "--verbose", action="store_true", help="Debug output")

    sub = parser.add_subparsers(dest="cmd", metavar="COMMAND")

    p_inst = sub.add_parser("install",    help="Install a package and its deps")
    p_inst.add_argument("package")

    p_upg = sub.add_parser("upgrade", help="Upgrade a package (or all if none specified)")
    p_upg.add_argument("package", nargs="?", help="Specific package to upgrade (optional)")

    p_rem = sub.add_parser("remove",     help="Remove an installed package")
    p_rem.add_argument("package")
    p_rem.add_argument("--force", action="store_true",
                       help="Remove even if other packages depend on it")

    p_run = sub.add_parser("run",        help="Run a package in a sandbox")
    p_run.add_argument("package")

    p_srch = sub.add_parser("search",    help="Search available packages")
    p_srch.add_argument("term")

    p_info = sub.add_parser("info",      help="Show details about a package")
    p_info.add_argument("package")

    p_lst = sub.add_parser("list",       help="List installed packages")
    p_lst.add_argument("-v", "--verbose", action="store_true",
                       dest="list_verbose", help="Show timestamps")

    sub.add_parser("sync",        help="Sync the package repository index")
    sub.add_parser("autoremove",  help="Remove unused auto-installed packages")
    sub.add_parser("test",        help="Run built-in self-tests")

    args = parser.parse_args()
    setup_logging(args.verbose)

    if args.cmd is None:
        parser.print_help()
        return

    try:
        repo = Repository()
        with PackageLock():
            match args.cmd:
                case "sync":
                    repo.sync()
                case "install":
                    require_root()
                    Installer(repo.repo).install(args.package)
                case "upgrade":
                    require_root()
                    if args.package:
                        Upgrader(repo.repo).upgrade_package(args.package)
                    else:
                        Upgrader(repo.repo).upgrade_all()
                case "remove":
                    require_root()
                    Remover(repo.repo).remove(args.package, force=args.force)
                case "autoremove":
                    require_root()
                    Remover(repo.repo).autoremove()
                case "run":
                    SandboxEngine(args.package).launch()
                case "list":
                    list_installed(verbose=args.list_verbose)
                case "search":
                    cmd_search(repo.repo, args.term)
                case "info":
                    cmd_info(repo.repo, args.package)
                case "test":
                    run_self_tests()

    except KeyboardInterrupt:
        print("\nAborted by user.")
        sys.exit(130)
    except LockError as exc:
        log.debug("Lock collision", exc_info=True)
        print(f"\n[Lock Error] {exc}", file=sys.stderr)
        print("Hint: If you are sure no other veropkg instance is running, delete veropkg_data/veropkg.lock", file=sys.stderr)
        sys.exit(1)
    except NetworkError as exc:
        log.debug("Network failure", exc_info=True)
        print(f"\n[Network Error] Could not reach the repository/package URL: {exc}", file=sys.stderr)
        print("Hint: Check your internet connection or repository URL.", file=sys.stderr)
        sys.exit(1)
    except ChecksumError as exc:
        log.error("Integrity check failed", exc_info=True)
        print(f"\n[Integrity Error] {exc}", file=sys.stderr)
        print("Hint: The package may be corrupted or compromised. Try clearing the cache.", file=sys.stderr)
        sys.exit(1)
    except DependencyError as exc:
        log.error("Dependency resolution failed", exc_info=True)
        print(f"\n[Dependency Error] {exc}", file=sys.stderr)
        sys.exit(1)
    except VeroPkgError as exc:
        log.debug("Generic veropkg error", exc_info=True)
        print(f"\n[Error] {exc}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
