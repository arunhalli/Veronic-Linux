# Paths
# ---------------------------------------------------------------------------

ROOT            = Path("./veropkg_data")
CACHE_DIR       = ROOT / "cache"
DB_DIR          = ROOT / "db"
TRANSACTION_DIR = ROOT / "transactions"
LOCKFILE        = ROOT / "veropkg.lock"

INSTALLED_DB = DB_DIR / "installed.json"
FILES_DB     = DB_DIR / "files.json"
REPO_DB      = DB_DIR / "repo.json"

SYSTEM_ROOT = Path(os.environ.get("VEROPKG_ROOT", str(ROOT / "system")))
SANDBOX_HOME = Path.home() / ".local/share/veronic_apps"

REPO_URL = "https://repo.veronic.linux/packages.json"

# Security limits
MAX_DOWNLOAD_BYTES = 512 * 1024 * 1024   # 512 MB per package
MAX_REPO_BYTES     = 10  * 1024 * 1024   # 10 MB repo index

# Package name: must start with alphanumeric, then [a-zA-Z0-9._+-]
_PKG_RE = re.compile(r'^[a-zA-Z0-9][a-zA-Z0-9._+\-]*$')

